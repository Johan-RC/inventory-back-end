<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Crea la tabla de categorías -->
    <changeSet id="1-create-categories" author="johan">
        <createTable tableName="categories">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Crea la tabla de proveedores -->
    <changeSet id="2-create-suppliers" author="johan">
        <createTable tableName="suppliers">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>

            <column name="email" type="VARCHAR(150)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Crea la tabla de productos -->
    <changeSet id="3-create-products" author="johan">
        <createTable tableName="products">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>

            <column name="price" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>

            <column name="category_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="supplier_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Relación: products.category_id -> categories.id -->
    <changeSet id="4-fk-products-category" author="johan">
        <addForeignKeyConstraint
                baseTableName="products"
                baseColumnNames="category_id"
                referencedTableName="categories"
                referencedColumnNames="id"
                constraintName="fk_products_category"/>
    </changeSet>

    <!-- Relación: products.supplier_id -> suppliers.id -->
    <changeSet id="5-fk-products-supplier" author="johan">
        <addForeignKeyConstraint
                baseTableName="products"
                baseColumnNames="supplier_id"
                referencedTableName="suppliers"
                referencedColumnNames="id"
                constraintName="fk_products_supplier"/>
    </changeSet>

</databaseChangeLog>